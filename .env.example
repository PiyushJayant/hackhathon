# ── Google Cloud ───────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
PROJECT_NUMBER=your-project-number

# Use Vertex AI backend (recommended for Cloud Run; uses ADC automatically)
GOOGLE_GENAI_USE_VERTEXAI=true

# OR use Gemini API key for local dev (comment out GOOGLE_GENAI_USE_VERTEXAI above):
# GOOGLE_API_KEY=your-gemini-api-key

# Model
MODEL=gemini-2.5-flash

# ── Service Account ───────────────────────────────────────────────────────────
SA_NAME=productivity-service
SERVICE_ACCOUNT=productivity-service@your-project-id.iam.gserviceaccount.com

# ── AlloyDB ────────────────────────────────────────────────────────────────────
ALLOYDB_REGION=us-central1
ALLOYDB_CLUSTER=productivity-cluster
ALLOYDB_INSTANCE=productivity-instance
ALLOYDB_IP_TYPE=private
ALLOYDB_DATABASE=postgres
ALLOYDB_USER=postgres
ALLOYDB_PASSWORD=your-alloydb-password

# ── MCP Toolbox ────────────────────────────────────────────────────────────────
# Local dev:  http://127.0.0.1:5000
# Cloud Run:  (auto-detected by deploy.sh from mcp-toolbox service URL)
TOOLBOX_URL=http://127.0.0.1:5000

# ── VPC Configuration (for private AlloyDB) ───────────────────────────────────
VPC_CONNECTOR=toolbox-vpc-connector
VPC_EGRESS=private-ranges-only
VPC_NETWORK=easy-alloydb-vpc
VPC_CONNECTOR_RANGE=10.8.0.0/28
VPC_CONNECTOR_RANGE_FALLBACK=10.9.0.0/28

# ── Cloud Run Service Names ───────────────────────────────────────────────────
REGION=us-central1
ASSISTANT_SERVICE_NAME=productivity-assistant
TOOLBOX_SERVICE_NAME=mcp-toolbox
AR_REPO=productivity-services
